generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String      @id @default(cuid())
  email                String      @unique
  senha_hash           String
  nome                 String
  role                 Role        @default(SEGUIDOR)
  indicado_por         IndicadoPor @default(COPYBET)
  analista_id_afiliado String?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  analista Analista?
  seguidor Seguidor?
  plano    Plano?
}

model Analista {
  id            String         @id @default(cuid())
  user_id       String         @unique
  bio           String?
  especialidade String?
  foto_url      String?
  status        StatusAnalista @default(PENDENTE)

  // Stats 1 unidade
  stats_1u_win_rate          Decimal @default(0) @db.Decimal(6, 2)
  stats_1u_rendimento_mes    Decimal @default(0) @db.Decimal(8, 2)
  stats_1u_rendimento_total  Decimal @default(0) @db.Decimal(8, 2)
  stats_1u_total_sinais      Int     @default(0)

  // Stats 0.5 unidade
  stats_05u_win_rate         Decimal @default(0) @db.Decimal(6, 2)
  stats_05u_rendimento_mes   Decimal @default(0) @db.Decimal(8, 2)
  stats_05u_rendimento_total Decimal @default(0) @db.Decimal(8, 2)
  stats_05u_total_sinais     Int     @default(0)

  // Stats 0.25 unidade
  stats_025u_win_rate         Decimal @default(0) @db.Decimal(6, 2)
  stats_025u_rendimento_mes   Decimal @default(0) @db.Decimal(8, 2)
  stats_025u_rendimento_total Decimal @default(0) @db.Decimal(8, 2)
  stats_025u_total_sinais     Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user        User               @relation(fields: [user_id], references: [id])
  sinais      Sinal[]
  seguidores  Seguidor[]
  fechamentos FechamentoMensal[]
}

model Seguidor {
  id              String  @id @default(cuid())
  user_id         String  @unique
  analista_id     String?
  feed_token_hash String? @unique

  unidade_valor Decimal @default(10) @db.Decimal(12, 2)
  aceita_1u     Boolean @default(true)
  aceita_0_5u   Boolean @default(true)
  aceita_0_25u  Boolean @default(false)
  ativo         Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user      User       @relation(fields: [user_id], references: [id])
  analista  Analista?  @relation(fields: [analista_id], references: [id])
  execucoes Execucao[]
}

model Sinal {
  id           String          @id @default(cuid())
  analista_id  String
  casa         String
  evento       String
  mercado      String
  odd          Decimal         @db.Decimal(8, 2)
  tipo_unidade TipoUnidade     @default(U1)
  status       StatusSinal     @default(PENDENTE)
  resultado    ResultadoSinal?

  // Campos Layer 2 — feed BfBotManager (opcionais: sinais Layer 1 nao precisam)
  market_id      String?
  selection_id   BigInt?
  selection_nome String?
  market_type    String?
  lado           LadoAposta?
  odd_pedida     Decimal?    @db.Decimal(8, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  analista  Analista   @relation(fields: [analista_id], references: [id])
  execucoes Execucao[]

  @@index([analista_id, status])
}

model Execucao {
  id             String         @id @default(cuid())
  sinal_id       String
  seguidor_id    String
  valor_apostado Decimal        @db.Decimal(12, 2)
  status         StatusExecucao @default(PENDENTE)
  lucro_prejuizo Decimal?       @db.Decimal(12, 2)
  erro_msg       String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  sinal    Sinal    @relation(fields: [sinal_id], references: [id])
  seguidor Seguidor @relation(fields: [seguidor_id], references: [id])

  @@index([seguidor_id, created_at])
  @@index([status])
}

model Plano {
  id                     String      @id @default(cuid())
  user_id                String      @unique
  status                 StatusPlano @default(INATIVO)
  valor_mensalidade      Decimal     @default(99.90) @db.Decimal(12, 2)
  data_inicio            DateTime?
  data_vencimento        DateTime?
  stripe_subscription_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])
}

model FechamentoMensal {
  id                       String          @id @default(cuid())
  data_fechamento          DateTime
  analista_id              String
  qtd_seguidores_ativos    Int
  valor_total_mensalidades Decimal         @db.Decimal(12, 2)
  percentual_comissao      Decimal         @default(0.30) @db.Decimal(5, 2)
  valor_comissao           Decimal         @db.Decimal(12, 2)
  status_pagamento         StatusPagamento @default(PENDENTE)

  created_at DateTime @default(now())

  analista Analista @relation(fields: [analista_id], references: [id])
}

// Enums
enum Role {
  SEGUIDOR
  ANALISTA
  ADMIN
}

enum IndicadoPor {
  ANALISTA
  COPYBET
}

enum TipoUnidade {
  U1
  U05
  U025
}

enum StatusSinal {
  PENDENTE
  ATIVO
  ENCERRADO
}

enum ResultadoSinal {
  GANHOU
  PERDEU
  VOID
}

enum StatusExecucao {
  PENDENTE
  EXECUTANDO
  SUCESSO
  FALHA
}

enum StatusPlano {
  ATIVO
  INATIVO
  CANCELADO
}

enum StatusPagamento {
  PENDENTE
  PAGO
  CANCELADO
}

enum StatusAnalista {
  PENDENTE
  APROVADO
  REJEITADO
}

enum LadoAposta {
  BACK
  LAY
}
